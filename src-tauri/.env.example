# Meridian's Jira OAuth 2.0 (3LO) app credentials.
#
# Copy this file to `.env` (which is gitignored) and fill in the values from
# your app at https://developer.atlassian.com/console/myapps/. build.rs bakes
# them into the binary so end users connect with one click and never see a
# client id/secret.
#
# Your Atlassian app must:
#   - register this exact callback URL:  http://localhost:33418/callback
#   - enable scopes:  read:jira-work  read:jira-user  offline_access
#
# A build without `.env` simply ships with Jira unconfigured (the Connections
# card says so) — nothing else breaks.

MERIDIAN_JIRA_CLIENT_ID=
MERIDIAN_JIRA_CLIENT_SECRET=
